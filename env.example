# AegisRAG MCP Server 环境变量（拷为 .env 使用）
# 独立部署时需能访问 Backend API

# ========== Backend API（必填）==========
# 后端 API 根地址，例如 http://localhost:8080/api/v1 或 http://backend-host:8080/api/v1
AEGIS_RAG_BASE_URL=http://localhost:8080/api/v1

# 若后端开启 API Key 认证则填写
# AEGIS_RAG_API_KEY=

# ========== 可选 ==========
# MCP 上游配置（JSON 数组），见 MCP_CONFIG.md
# MCP_UPSTREAM_CONFIG=[{"name":"...","command":"...","args":[]}]
